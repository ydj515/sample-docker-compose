# Compose 프로젝트명. 기본값: elk
COMPOSE_PROJECT_NAME=elk

# 공통 타임존. 기본값: Asia/Seoul
TZ=Asia/Seoul

# Elastic Stack 이미지 버전. 2026-02-26 기준 최신 공식 릴리스: 9.3.1
ELASTIC_VERSION=9.3.1

# 공식 이미지 경로들
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch
KIBANA_IMAGE=docker.elastic.co/kibana/kibana
LOGSTASH_IMAGE=docker.elastic.co/logstash/logstash
METRICBEAT_IMAGE=docker.elastic.co/beats/metricbeat

# Grafana OSS 이미지 버전. 기본값: 11.5.2
GRAFANA_IMAGE=grafana/grafana-oss
GRAFANA_VERSION=11.5.2

# Elasticsearch bootstrap 비밀번호. 반드시 변경 권장
ELASTIC_PASSWORD=changeme

# 서비스 계정 비밀번호들. setup 컨테이너가 자동 생성/갱신합니다.
KIBANA_SYSTEM_PASSWORD=changeme_kibana
LOGSTASH_INTERNAL_PASSWORD=changeme_logstash
METRICBEAT_INTERNAL_PASSWORD=changeme_metricbeat
GRAFANA_INTERNAL_PASSWORD=changeme_grafana

# 클러스터 기본 식별자
ELASTIC_CLUSTER_NAME=elk-prod-cluster

# Elasticsearch 외부 API 포트. 기본값: 9200
ELASTICSEARCH_PORT=9200
# 내부 서비스 URL. 기본값: ingest 노드
ELASTICSEARCH_URL=http://es-ingest01:9200

# 마스터 노드 권장값
ES_MASTER_HEAP_SIZE=512m
ES_MASTER_MEMORY_LIMIT=1g

# 데이터 노드 권장값
ES_DATA_HEAP_SIZE=768m
ES_DATA_MEMORY_LIMIT=1536m

# ingest/coordinating 노드 권장값
ES_INGEST_HEAP_SIZE=512m
ES_INGEST_MEMORY_LIMIT=1g

# Kibana 설정
KIBANA_PORT=5601
KIBANA_PUBLIC_BASE_URL=http://localhost:5601
# 32자 이상 랜덤 문자열 권장
KIBANA_ENCRYPTION_KEY=change-this-to-a-random-32-char-string

# Logstash 설정
LOGSTASH_BEATS_PORT=5044
LOGSTASH_TCP_PORT=50000
LOGSTASH_API_PORT=9600
LOGSTASH_INDEX_PREFIX=logstash
LOGSTASH_HEAP_SIZE=512m
LOGSTASH_PIPELINE_WORKERS=2

# Metricbeat 설정
KIBANA_INTERNAL_URL=http://kibana:5601
LOGSTASH_MONITORING_URL=http://logstash:9600
METRICBEAT_HTTP_PORT=5066
# Docker 메트릭 권장 수집 주기. 기본값: 30s
METRICBEAT_DOCKER_PERIOD=30s
# Stack 모니터링 권장 수집 주기. 기본값: 30s
METRICBEAT_STACK_PERIOD=30s

# Grafana 설정
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin1234
GRAFANA_ROOT_URL=http://localhost:3000
GRAFANA_LOG_INDEX_PATTERN=logstash-*
GRAFANA_METRIC_INDEX_PATTERN=metricbeat-*
