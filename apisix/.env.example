# Compose 프로젝트명입니다. 기본값은 디렉터리명 기반으로 잡히므로 로컬 구분이 필요할 때만 바꾸면 됩니다.
COMPOSE_PROJECT_NAME=apisix-local

# 공통
# 기본값: Asia/Seoul
TZ=Asia/Seoul

# 이미지 버전
# 기본값: 공식 stable 태그를 쓰되, 로컬 재현성을 위해 patch 버전까지 고정하는 것을 권장합니다.
BACKEND_IMAGE=nginx:1.27.4-alpine
NGINX_IMAGE=nginx:1.27.4
REDIS_IMAGE=redis:7.4.2
# Bitnami 공개 카탈로그 변경으로 기존 버전 태그는 bitnamilegacy 저장소를 사용합니다.
ETCD_IMAGE=bitnamilegacy/etcd:3.5.11
PROMETHEUS_IMAGE=prom/prometheus:v2.48.0
GRAFANA_IMAGE=grafana/grafana:11.5.2
APISIX_BASE_IMAGE=apache/apisix:3.11.0-debian

# 컨테이너 이름
# 기본값: service name 기반으로 자동 생성되지만, 운영/디버깅 편의를 위해 명시값 사용을 권장합니다.
BACKEND_CONTAINER_NAME=apisix-backend
NGINX_CONTAINER_NAME=apisix-nginx
REDIS_CONTAINER_NAME=apisix-redis
ETCD1_CONTAINER_NAME=apisix-etcd-1
ETCD2_CONTAINER_NAME=apisix-etcd-2
ETCD3_CONTAINER_NAME=apisix-etcd-3
APISIX1_CONTAINER_NAME=apisix-1
APISIX2_CONTAINER_NAME=apisix-2
PROMETHEUS_CONTAINER_NAME=apisix-prometheus
LIMIT_REQ_EXPORTER_CONTAINER_NAME=apisix-limit-req-exporter
GRAFANA_CONTAINER_NAME=apisix-grafana

# 외부 노출 포트
# 기본값: 기존 샘플 compose와 동일한 포트 체계를 유지했습니다.
BACKEND_PORT=8081
NGINX_HTTP_PORT=80
REDIS_PORT=6379
ETCD1_CLIENT_PORT=2379
ETCD2_CLIENT_PORT=2479
ETCD3_CLIENT_PORT=2579
PROMETHEUS_PORT=9090
LIMIT_REQ_EXPORTER_PORT=8000
GRAFANA_PORT=3000
APISIX1_ADMIN_PORT=9180
APISIX1_GATEWAY_PORT=9080
APISIX1_METRICS_PORT=9091
APISIX1_SSL_PORT=9443
APISIX1_CONTROL_PORT=9092
APISIX2_ADMIN_PORT=9280
APISIX2_GATEWAY_PORT=9181
APISIX2_METRICS_PORT=9191
APISIX2_SSL_PORT=9543
APISIX2_CONTROL_PORT=9192

# backend 서비스 기본 설정
# 기본값: 8080
BACKEND_INTERNAL_PORT=8080
# 기본값: /api/health
BACKEND_HEALTHCHECK_PATH=/api/health

# APISIX 공통 설정
# 기본값: 9080
APISIX_NODE_LISTEN=9080
# 기본값: 9091
APISIX_PROMETHEUS_EXPORT_PORT=9091
# 기본값: 9092
APISIX_CONTROL_API_PORT=9092
# 기본값: false
APISIX_ENABLE_IPV6=false
# 기본값: info
APISIX_LOG_LEVEL=info
# 기본값: 0.0.0.0/0
# 운영에서는 반드시 사내망 또는 특정 IP 대역으로 제한하는 것을 권장합니다.
APISIX_ADMIN_ALLOW_CIDR=0.0.0.0/0
# 기본값: 로컬 개발용 샘플 키입니다. 외부 공유 환경에서는 반드시 교체하세요.
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1
# 기본값: 조회 전용 키입니다.
APISIX_VIEWER_KEY=4054f7cf07e344346cd3f287985e76a2
# 기본값: etcd 3노드 클러스터를 모두 바라보도록 구성합니다.
APISIX_ETCD_HOST_1=http://etcd1:2379
APISIX_ETCD_HOST_2=http://etcd2:2379
APISIX_ETCD_HOST_3=http://etcd3:2379
# 기본값: 30
APISIX_ETCD_TIMEOUT=30
# 기본값: 512m
APISIX_JAVA_XMS=512m
# 기본값: 1024m
APISIX_JAVA_XMX=1024m
# 기본값: 10m
APISIX_UPSTREAM_HEALTHCHECK_DICT_SIZE=10m

# active_health_control 플러그인 기본값
# 기본값: 10
APISIX_HEALTH_CHECK_INTERVAL=10
# 기본값: /api/health
APISIX_HEALTH_CHECK_PATH=/api/health
# 기본값: 200
APISIX_HEALTH_EXPECTED_STATUS=200
# 기본값: 503
APISIX_HEALTH_REWRITE_CODE=503
# 기본값: {"message":"점검 중입니다."}
APISIX_HEALTH_REWRITE_BODY={"message":"점검 중입니다."}

# Redis 권장 설정
# 기본값: yes
REDIS_APPENDONLY=yes
# 기본값: 60 1000
# 60초 동안 1000건 이상 변경되면 RDB 스냅샷을 수행합니다.
REDIS_SAVE_SECONDS=60
REDIS_SAVE_CHANGES=1000
# 기본값: 256mb
REDIS_MAXMEMORY=256mb
# 기본값: allkeys-lru
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ETCD 권장 설정
# 기본값: revision
ETCD_AUTO_COMPACTION_MODE=revision
# 기본값: 1000
ETCD_AUTO_COMPACTION_RETENTION=1000
# 기본값: 10000
ETCD_SNAPSHOT_COUNT=10000
# 기본값: 100
ETCD_HEARTBEAT_INTERVAL=100
# 기본값: 1000
ETCD_ELECTION_TIMEOUT=1000
# 기본값: 2147483648 (2GiB)
ETCD_QUOTA_BACKEND_BYTES=2147483648
# 기본값: apisix-etcd-cluster
ETCD_INITIAL_CLUSTER_TOKEN=apisix-etcd-cluster
# 기본값: new
ETCD_INITIAL_CLUSTER_STATE=new
# 기본값: etcd1=http://etcd1:2380,etcd2=http://etcd2:2380,etcd3=http://etcd3:2380
ETCD_INITIAL_CLUSTER=etcd1=http://etcd1:2380,etcd2=http://etcd2:2380,etcd3=http://etcd3:2380

# Prometheus 권장 설정
# 기본값: 7d
PROMETHEUS_RETENTION_TIME=7d
# 기본값: 1GB
PROMETHEUS_RETENTION_SIZE=1GB

# limit_req_exporter 설정
# 기본값: http://apisix1:9180/apisix/admin/routes
LIMIT_REQ_EXPORTER_ADMIN_API_URL=http://apisix1:9180/apisix/admin/routes
# 기본값: 1
LIMIT_REQ_EXPORTER_INTERVAL_SECONDS=1
# 기본값: 8000
LIMIT_REQ_EXPORTER_INTERNAL_PORT=8000
# 기본값: 5
LIMIT_REQ_EXPORTER_TIMEOUT_SECONDS=5

# APISIX Admin API 샘플 스크립트 설정
# 기본값: 두 번째 APISIX Admin API 포트(9280)를 기본 호출 대상으로 사용합니다.
APISIX_ADMIN_BASE_URL=http://127.0.0.1:9280
# 기본값: 클러스터 내부에서 active_health_control 이 접근할 Admin API 주소입니다.
APISIX_CLUSTER_ADMIN_API_URL=http://apisix1:9180
# 기본값: 1000
APISIX_SAMPLE_UPSTREAM_ID=1000
# 기본값: 1000
APISIX_SAMPLE_ROUTE_ID=1000
# 기본값: /api/*
APISIX_SAMPLE_ROUTE_URI=/api/*
# 기본값: compose 네트워크 내부 backend 서비스명입니다.
APISIX_SAMPLE_UPSTREAM_HOST=backend
# 기본값: backend 내부 포트입니다.
APISIX_SAMPLE_UPSTREAM_PORT=8080
# 기본값: GET,POST
APISIX_SAMPLE_METHODS=GET,POST
# 기본값: backend 서비스의 health check URL 입니다.
APISIX_SAMPLE_HEALTH_CHECK_URL=http://backend:8080/api/health
# 기본값: 200
APISIX_SAMPLE_HEALTH_EXPECTED_STATUS=200
# 기본값: 200
APISIX_SAMPLE_LIMIT_REQ_RATE=200
# 기본값: 20
APISIX_SAMPLE_LIMIT_REQ_BURST=20
# 기본값: DemoFilter
APISIX_SAMPLE_EXT_PLUGIN_FILTER_NAME=DemoFilter

# Grafana 권장 설정
# 기본값: admin
GRAFANA_ADMIN_USER=admin
# 기본값: admin1234!
# 외부 접근 환경에서는 반드시 변경하세요.
GRAFANA_ADMIN_PASSWORD=admin1234!
# 기본값: http://localhost:3000
GRAFANA_ROOT_URL=http://localhost:3000
