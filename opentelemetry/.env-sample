# Compose project
COMPOSE_PROJECT_NAME=otel-demo
OTEL_NETWORK_NAME=otel-demo

# Images
COLLECTOR_CONTRIB_IMAGE=otel/opentelemetry-collector-contrib:0.147.0
PROMETHEUS_IMAGE=prom/prometheus:v2.48.0
JAEGER_IMAGE=jaegertracing/jaeger:2.16.0
TEMPO_IMAGE=grafana/tempo:2.10.2
LOKI_IMAGE=grafana/loki:3.0.0
ALLOY_IMAGE=grafana/alloy:v1.12.1
GRAFANA_IMAGE=grafana/grafana:11.5.2
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.9.1

# Named volumes
GRAFANA_VOLUME_NAME=otel-grafana-data
PROMETHEUS_VOLUME_NAME=otel-prometheus-data
TEMPO_VOLUME_NAME=otel-tempo-data
LOKI_VOLUME_NAME=otel-loki-data
JAEGER_VOLUME_NAME=otel-jaeger-data
ALLOY_VOLUME_NAME=otel-alloy-data

# Host ports
OTEL_COLLECTOR_HOST_PORT_PPROF=1888
OTEL_COLLECTOR_HOST_PORT_METRICS=8888
OTEL_COLLECTOR_HOST_PORT_EXPORTER_METRICS=8889
OTEL_COLLECTOR_HOST_PORT_HEALTHCHECK=13133
OTEL_COLLECTOR_HOST_PORT_GRPC=4317
OTEL_COLLECTOR_HOST_PORT_HTTP=4318
OTEL_COLLECTOR_HOST_PORT_ZPAGES=55679
JAEGER_HOST_PORT_UI=16686
PROMETHEUS_HOST_PORT=9090
TEMPO_HOST_PORT=3200
LOKI_HOST_PORT=3100
GRAFANA_HOST_PORT=3000
GRAFANA_FEATURE_TOGGLES_ENABLE=traceqlEditor
NODE_EXPORTER_HOST_PORT=9100
ALLOY_HOST_PORT=12345
ALLOY_LOG_PATH=/var/log

# 애플리케이션에서 Collector로 직접 보낼 때 사용할 외부 엔드포인트입니다.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# 브라우저 앱에서 직접 보낼 때는 HTTP 엔드포인트를 사용하세요.
# PUBLIC_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
