logging {
  // Alloy 기본값: "info"
  // 로컬 개발 권장값: "info"
  level  = "info"
  // Alloy 기본값: "logfmt"
  // 로컬 개발 권장값: "logfmt"
  format = "logfmt"
}

local.file_match "varlogs" {
  // Alloy 기본값: 10s
  // 로컬 개발 권장값: 10s
  sync_period = "10s"
  path_targets = [
    {
      __path__ = "/var/log/*log",
      job      = "varlogs",
    },
  ]
}

