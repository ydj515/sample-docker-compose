loki.source.file "varlogs" {
  targets    = local.file_match.varlogs.targets
  forward_to = [loki.write.default.receiver]

  // Alloy 기본값: false
  // 로컬 개발 권장값: false
  // 기존 Promtail과 비슷하게 첫 수집 시 파일 처음부터 읽습니다.
  tail_from_end = false

  file_watch {
    // Alloy 기본값: 250ms
    // 로컬 개발 권장값: 250ms
    min_poll_frequency = "250ms"
    // Alloy 기본값: 250ms
    // 로컬 개발 권장값: 250ms
    max_poll_frequency = "250ms"
  }

}

